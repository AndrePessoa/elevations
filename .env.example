# SFTP Configuration for Deployment
# Copy this file to .env and fill in your actual values

# SFTP hostname
SFTP_HOST=sftp.example.com

# Your SFTP username
SFTP_USER=your_username

# Your SFTP password
SFTP_PASS=your_password

# Remote path to the deploy target
SFTP_PATH=/path/to/deploy/target

# Optional: SFTP port (defaults to 22 if not specified)
# SFTP_PORT=22
